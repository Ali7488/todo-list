{
  "name": "todo-list",
  "version": "1.0.0",
  "description": "a basic todo-list app",
  "main": "webpack.common.js",
  "scripts": {
    "start": "webpack serve --config webpack.dev.js",
    "dev": "webpack serve --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js",
    "predeploy": "npm run build",
    "deploy": "git add dist -f && git commit -m \"Deployment commit\" && git subtree push --prefix dist origin gh-pages",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ali7488/my-code-template.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Ali7488/todo-list/issues"
  },
  "homepage": "https://github.com/Ali7488/todo-list#readme",
  "devDependencies": {
    "css-loader": "^7.1.4",
    "eslint": "^10.6.0",
    "html-webpack-plugin": "^5.6.7",
    "prettier": "^3.9.4",
    "style-loader": "^4.0.0",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "webpack-dev-server": "^5.2.5",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "date-fns": "^4.4.0"
  }
}
